#!/usr/bin/env bash
# 描述： APT/Snap/Flatpak安装软件的TUI
# Description: APT/Snap/Flatpak pkg installation TUI
# ==============================================================================
set -euo pipefail

ORIGINAL_LANG="${LC_ALL:-${LC_MESSAGES:-${LANG:-C}}}"
export LC_ALL=C

# --- 0. 内部生成器拦截 (由 fzf reload 或后台进程触发) ---
if [[ "${1:-}" == "--generate-list" ]]; then
    FORCE_REFRESH="$2"
    INSTALLED_LIST="$3"
    SNAP_CACHE="$4"
    MSG_INSTALLED="$5"
    FLATPAK_CACHE="$6"
    SHOW_APT="${7:-true}"
    SHOW_SNAP="${8:-true}"
    SHOW_FLATPAK="${9:-true}"
    CACHE_TIME=3600

    AWK_CMD='
        function ellipsize(s, n) {
            return (length(s) > n) ? substr(s, 1, n - 1) "~" : s
        }
        FNR==NR { installed[$1]=1; next }
        {
            status = ($2 in installed) ? ci " ✔ " label r : ""
            src = ellipsize($1, 18)
            pkg = ellipsize($2, 42)
            ver = ellipsize($3, 22)
            printf "%s%-18s%s %-42s %-22s %s\t%s\t%s\n", c, src, r, pkg, ver, status, $1, $2
        }
    '

    dpkg-query -W -f '${binary:Package}\n' 2>/dev/null > "$INSTALLED_LIST" || true
    flatpak list --user --app --columns=application 2>/dev/null >> "$INSTALLED_LIST" || true
    flatpak list --system --app --columns=application 2>/dev/null >> "$INSTALLED_LIST" || true

    if [[ "$SHOW_APT" == true ]]; then
        apt list 2>/dev/null | awk -v c='\033[34m' -v ci='\033[32m' -v r='\033[0m' \
            -v label="$MSG_INSTALLED" '
            NR==1 || /^WARNING/ { next }
            {
                split($0, a, "/")
                pkg = a[1]
                rest = a[2]
                split(rest, f, " ")
                repo = f[1]; sub(/,now$/, "", repo)
                ver = f[2]; gsub(/\[.*\]/, "", ver); gsub(/^ +| +$/, "", ver)
                if (ver == "") ver = "-"
                print repo, pkg, ver
            }
        ' | awk -v c='\033[34m' -v ci='\033[32m' -v r='\033[0m' \
            -v label="$MSG_INSTALLED" \
            "$AWK_CMD" "$INSTALLED_LIST" -
    fi

    if [[ "$SHOW_SNAP" == true ]] && command -v snap >/dev/null 2>&1; then
        NEED_UPDATE=false
        if [[ "$FORCE_REFRESH" == true ]] || [[ ! -s "$SNAP_CACHE" ]]; then
            NEED_UPDATE=true
        elif [[ $(find "$SNAP_CACHE" -mmin +$((CACHE_TIME / 60)) 2>/dev/null) ]]; then
            NEED_UPDATE=true
        fi
        if [[ "$NEED_UPDATE" == true ]]; then
            snap find 2>/dev/null | tail -n +2 | awk '{print "snap", $1, $2}' > "${SNAP_CACHE}.tmp" 2>/dev/null || true
            if [[ -s "${SNAP_CACHE}.tmp" ]]; then
                mv "${SNAP_CACHE}.tmp" "$SNAP_CACHE"
            else
                rm -f "${SNAP_CACHE}.tmp"
            fi
        fi
        if [[ -s "$SNAP_CACHE" ]]; then
            awk -v c='\033[35m' -v ci='\033[32m' -v r='\033[0m' \
                -v label="$MSG_INSTALLED" \
                "$AWK_CMD" "$INSTALLED_LIST" "$SNAP_CACHE"
        fi
    fi

    if [[ "$SHOW_FLATPAK" == true ]] && command -v flatpak >/dev/null 2>&1; then
        NEED_UPDATE=false
        if [[ "$FORCE_REFRESH" == true ]] || [[ ! -s "$FLATPAK_CACHE" ]]; then
            NEED_UPDATE=true
        elif [[ $(find "$FLATPAK_CACHE" -mmin +$((CACHE_TIME / 60)) 2>/dev/null) ]]; then
            NEED_UPDATE=true
        fi
        if [[ "$NEED_UPDATE" == true ]]; then
            if flatpak remote-ls --user flathub --app --columns=application,version 2>/dev/null \
                | awk -F'\t' '{print "flatpak", $1, $2}' > "${FLATPAK_CACHE}.tmp" 2>/dev/null; then
                :
            elif flatpak remote-ls --system flathub --app --columns=application,version 2>/dev/null \
                | awk -F'\t' '{print "flatpak", $1, $2}' > "${FLATPAK_CACHE}.tmp" 2>/dev/null; then
                :
            fi
            if [[ -s "${FLATPAK_CACHE}.tmp" ]]; then
                mv "${FLATPAK_CACHE}.tmp" "$FLATPAK_CACHE"
            else
                rm -f "${FLATPAK_CACHE}.tmp"
            fi
        fi
        if [[ -s "$FLATPAK_CACHE" ]]; then
            awk -v c='\033[36m' -v ci='\033[32m' -v r='\033[0m' \
                -v label="$MSG_INSTALLED" \
                "$AWK_CMD" "$INSTALLED_LIST" "$FLATPAK_CACHE"
        fi
    fi
    exit 0
fi

# --- 1. 环境与基础配置 ---
SHOW_HELP=false
FORCE_REFRESH=false
FZF_EXACT=false
SHOW_APT=true
SHOW_SNAP=true
SHOW_FLATPAK=true
SOURCE_SPECIFIED=false
QUERY_ARGS=()
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/ubti_tui"

while [[ $# -gt 0 ]]; do
    case "$1" in
        --help|-h) SHOW_HELP=true; shift ;;
        --refresh|-y) FORCE_REFRESH=true; shift ;;
        --exact|-e) FZF_EXACT=true; shift ;;
        --apt)
            if [[ "$SOURCE_SPECIFIED" == false ]]; then
                SHOW_APT=false; SHOW_SNAP=false; SHOW_FLATPAK=false; SOURCE_SPECIFIED=true
            fi
            SHOW_APT=true; shift ;;
        --snap)
            if [[ "$SOURCE_SPECIFIED" == false ]]; then
                SHOW_APT=false; SHOW_SNAP=false; SHOW_FLATPAK=false; SOURCE_SPECIFIED=true
            fi
            SHOW_SNAP=true; shift ;;
        --flatpak)
            if [[ "$SOURCE_SPECIFIED" == false ]]; then
                SHOW_APT=false; SHOW_SNAP=false; SHOW_FLATPAK=false; SOURCE_SPECIFIED=true
            fi
            SHOW_FLATPAK=true; shift ;;
        *) QUERY_ARGS+=("$1"); shift ;;
    esac
done

SCRIPT_PATH="$(realpath "$0" 2>/dev/null || echo "$0")"

# --- 2. 本地化多语言字典 ---
declare -A MSG
if [[ "$ORIGINAL_LANG" == *"zh_CN"* ]]; then
    MSG[DESC]="模糊搜索并安装软件包 (支持 APT / Snap / Flatpak)。"
    MSG[OPTS]="选项："
    MSG[OPT_HELP]="  --help, -h    显示此帮助信息并退出"
    MSG[OPT_REFRESH]="  --refresh, -y 强制刷新 Snap 软件包本地缓存列表"
    MSG[OPT_EXACT]="  --exact, -e   关闭模糊匹配，使用精确匹配模式"
    MSG[OPT_SOURCES]="  --apt, --snap, --flatpak  选择数据源（可组合，默认全部展示）"
    MSG[FEAT]="功能特性："
    MSG[FEAT_1]="- 三源合一：APT (蓝) | Snap (紫) | Flatpak (青)"
    MSG[FEAT_2]="- 准确状态：显示 [已安装] 标记"
    MSG[FEAT_3]="- 快捷刷新：fzf 界面内按 Ctrl+R 强制重载并拉取最新缓存"
    MSG[EX]="示例："
    MSG[ERR_FZF]="错误：未找到 fzf，请先安装 (sudo apt install fzf)。"
    MSG[INSTALLED]="[已安装]"
    MSG[INSTALLING]=">> 准备安装："
    MSG[HEADER]="Tab:多选 | Enter:安装 | Ctrl+R:刷新 | Ctrl+E:精确/模糊 | Esc:退出"
    MSG[EXEC]="> 正在执行: "
    MSG[HINT]="如需重试或记录，可复制以下命令："
else
    MSG[DESC]="Fuzzy search & install packages (APT / Snap / Flatpak)."
    MSG[OPTS]="Options:"
    MSG[OPT_HELP]="  --help, -h    Show this help and exit"
    MSG[OPT_REFRESH]="  --refresh, -y Force refresh Snap package cache list"
    MSG[OPT_EXACT]="  --exact, -e   Disable fuzzy matching and use exact matching mode"
    MSG[OPT_SOURCES]="  --apt, --snap, --flatpak  Select data sources (combinable, default: all)"
    MSG[FEAT]="Features:"
    MSG[FEAT_1]="- Triple source: APT (Blue) | Snap (Purple) | Flatpak (Cyan)"
    MSG[FEAT_2]="- Accurate status: [Installed] tag"
    MSG[FEAT_3]="- Quick refresh: Ctrl+R in TUI to force reload"
    MSG[EX]="Example:"
    MSG[ERR_FZF]="Error: fzf not found. Install: sudo apt install fzf"
    MSG[INSTALLED]="[Installed]"
    MSG[INSTALLING]=">> Installing:"
    MSG[HEADER]="Tab:Multi | Enter:Install | Ctrl+R:Refresh | Ctrl+E:Exact/Fuzzy | Esc:Exit"
    MSG[EXEC]="> Executing: "
    MSG[HINT]="For retry or logging, copy the command below:"
fi

# --- 3. 帮助信息拦截 ---
if [ "$SHOW_HELP" = true ]; then
    cat <<EOF
Usage: ${0##*/} [options] [query]

${MSG[OPTS]}
${MSG[OPT_HELP]}
${MSG[OPT_REFRESH]}
${MSG[OPT_EXACT]}
${MSG[OPT_SOURCES]}

Description:
  ${MSG[DESC]}

${MSG[FEAT]}
  ${MSG[FEAT_1]}
  ${MSG[FEAT_2]}
  ${MSG[FEAT_3]}

${MSG[EX]}
  ${0##*/} firefox              # search across all sources
  ${0##*/} --flatpak firefox    # search flatpak only
  ${0##*/} --apt --snap vim     # search APT + Snap only
  ${0##*/} -y                   # force refresh cache
EOF
    exit 0
fi

# --- 4. 核心依赖检查 ---
command -v fzf >/dev/null 2>&1 || { echo "${MSG[ERR_FZF]}" >&2; exit 1; }

# --- 5. 异步逻辑与文件安全设置 ---
TMP_DIR=$(mktemp -d -t ubti_fzf.XXXXXX)
TARGET_FILE="${TMP_DIR}/target"
INSTALLED_LIST="${TMP_DIR}/installed"
PIPE_FIFO="${TMP_DIR}/fifo"
mkdir -p "$CACHE_DIR"
SNAP_CACHE="${CACHE_DIR}/snap_packages.txt"
FLATPAK_CACHE="${CACHE_DIR}/flatpak_packages.txt"
mkfifo "$PIPE_FIFO"

PREVIEW_CMD="export LC_ALL=\"$ORIGINAL_LANG\"; line={}; src=\$(printf '%s\n' \"\$line\" | awk -F'\t' '{print \$2}'); pkg=\$(printf '%s\n' \"\$line\" | awk -F'\t' '{print \$3}'); if [[ \"\$src\" == snap ]]; then snap info \"\$pkg\" 2>/dev/null; elif [[ \"\$src\" == flatpak ]]; then flatpak remote-info --user flathub \"\$pkg\" 2>/dev/null || flatpak remote-info --system flathub \"\$pkg\" 2>/dev/null; else apt-cache show \"\$pkg\" 2>/dev/null | head -60; fi"

cleanup() {
    if [[ -n "${PID_GEN:-}" ]]; then kill "$PID_GEN" 2>/dev/null || true; fi
    rm -rf "$TMP_DIR"
}
abort() { cleanup; exit 130; }
trap cleanup EXIT
trap abort INT TERM

# --- 6. 数据生成器 (后台运行) ---
"$SCRIPT_PATH" --generate-list "$FORCE_REFRESH" "$INSTALLED_LIST" "$SNAP_CACHE" "${MSG[INSTALLED]}" "$FLATPAK_CACHE" "$SHOW_APT" "$SHOW_SNAP" "$SHOW_FLATPAK" > "$PIPE_FIFO" 2>/dev/null &
PID_GEN=$!

# --- 7. 交互式 FZF 渲染 ---
COLOR_BLUE=$'\033[34m'
COLOR_PURPLE=$'\033[35m'
COLOR_CYAN=$'\033[36m'
COLOR_RESET=$'\033[0m'
FZF_MATCH_OPTIONS=()
if [[ "$FZF_EXACT" == true ]]; then
    FZF_MATCH_OPTIONS+=(--exact)
fi
FZF_HEADER="${MSG[HEADER]}"
if [[ "$SHOW_APT" == true ]]; then
    FZF_HEADER+=" | ${COLOR_BLUE}APT${COLOR_RESET}"
fi
if [[ "$SHOW_SNAP" == true ]]; then
    FZF_HEADER+=" | ${COLOR_PURPLE}Snap${COLOR_RESET}"
fi
if [[ "$SHOW_FLATPAK" == true ]]; then
    FZF_HEADER+=" | ${COLOR_CYAN}Flatpak${COLOR_RESET}"
fi

RELOAD_CMD=$(printf "%q " "$SCRIPT_PATH" --generate-list true "$INSTALLED_LIST" "$SNAP_CACHE" "${MSG[INSTALLED]}" "$FLATPAK_CACHE" "$SHOW_APT" "$SHOW_SNAP" "$SHOW_FLATPAK"); RELOAD_CMD="${RELOAD_CMD% }"

set +e
fzf --multi --ansi \
    "${FZF_MATCH_OPTIONS[@]}" \
    --delimiter=$'\t' \
    --with-nth=1 \
    --preview "$PREVIEW_CMD" \
    --preview-window=down:55%:wrap \
    --height=95% --layout=reverse --border \
    --bind "alt-j:last,alt-k:first" \
    --bind "ctrl-e:toggle-exact" \
    --bind "ctrl-r:reload(${RELOAD_CMD})" \
    --tiebreak=index \
    --header "$FZF_HEADER" \
    --query "${QUERY_ARGS[*]:-}" \
    < "$PIPE_FIFO" \
    > "$TARGET_FILE"
FZF_EXIT=$?
set -e

# --- 8. 执行安装 ---
if [[ $FZF_EXIT -eq 0 ]] && [[ -s "$TARGET_FILE" ]]; then
    mapfile -t SELECTED_LINES < "$TARGET_FILE"
    APT_PACKAGES=()
    SNAP_PACKAGES=()
    FLATPAK_PACKAGES=()

    for line in "${SELECTED_LINES[@]}"; do
        src=$(printf '%s\n' "$line" | awk -F'\t' '{print $2}')
        pkg=$(printf '%s\n' "$line" | awk -F'\t' '{print $3}')
        [[ -z "$src" || -z "$pkg" ]] && continue
        if [[ "$src" == "snap" ]]; then
            SNAP_PACKAGES+=("$pkg")
        elif [[ "$src" == "flatpak" ]]; then
            FLATPAK_PACKAGES+=("$pkg")
        else
            APT_PACKAGES+=("$pkg")
        fi
    done

    if [[ ${#APT_PACKAGES[@]} -gt 0 ]]; then
        echo -e "\n\033[32m${MSG[INSTALLING]}\033[0m"
        echo "${APT_PACKAGES[*]}"
        echo "----------------------------------------"
        FINAL_CMD="sudo apt install ${APT_PACKAGES[*]}"
        echo -e "\033[90m${MSG[EXEC]}$FINAL_CMD\033[0m\n"
        LC_ALL="$ORIGINAL_LANG" sudo apt install "${APT_PACKAGES[@]}"
        echo "----------------------------------------"
        echo -e "\033[36m${MSG[HINT]}\033[0m"
        echo -e "\033[1;33m$FINAL_CMD\033[0m\n"
    fi

    if [[ ${#SNAP_PACKAGES[@]} -gt 0 ]]; then
        echo -e "\n\033[32m${MSG[INSTALLING]}\033[0m"
        echo "${SNAP_PACKAGES[*]}"
        echo "----------------------------------------"
        FINAL_CMD="sudo snap install ${SNAP_PACKAGES[*]}"
        echo -e "\033[90m${MSG[EXEC]}$FINAL_CMD\033[0m\n"
        LC_ALL="$ORIGINAL_LANG" sudo snap install "${SNAP_PACKAGES[@]}"
        echo "----------------------------------------"
        echo -e "\033[36m${MSG[HINT]}\033[0m"
        echo -e "\033[1;33m$FINAL_CMD\033[0m\n"
    fi

    if [[ ${#FLATPAK_PACKAGES[@]} -gt 0 ]]; then
        echo -e "\n\033[32m${MSG[INSTALLING]}\033[0m"
        echo "${FLATPAK_PACKAGES[*]}"
        echo "----------------------------------------"
        if ! flatpak remotes --user 2>/dev/null | grep -q flathub; then
            echo -e "\033[33m当前用户未配置 flathub，正在添加用户级 flathub 远程...\033[0m"
            timeout 45s flatpak remote-add --user --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo
        fi
        FINAL_CMD="flatpak install --user flathub ${FLATPAK_PACKAGES[*]}"
        echo -e "\033[90m${MSG[EXEC]}$FINAL_CMD\033[0m\n"
        LC_ALL="$ORIGINAL_LANG" flatpak install --user flathub "${FLATPAK_PACKAGES[@]}"
        echo "----------------------------------------"
        echo -e "\033[36m${MSG[HINT]}\033[0m"
        echo -e "\033[1;33m$FINAL_CMD\033[0m\n"
    fi
fi
